<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F4E7">

    <!-- Decorative Leaf -->
    <ImageView
        android:id="@+id/imgLeaf"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="-55dp"
        android:layout_marginEnd="-80dp"
        android:rotation="-25"
        android:scaleType="fitCenter"
        android:src="@drawable/leaf"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Habits"
        android:textSize="48sp"
        android:textStyle="bold"
        android:textColor="#7FA48A"
        android:fontFamily="@font/capriola_regular"
        android:layout_marginStart="28dp"
        android:layout_marginTop="42dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Current Habits -->
    <TextView
        android:id="@+id/tvCurrent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Current Habits"
        android:textSize="36sp"
        android:textColor="#555555"
        android:fontFamily="@font/dongle_regular"
        android:layout_marginStart="28dp"
        android:layout_marginTop="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvEmptyCurrent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:text="No habits yet."
        android:textColor="#8A8A8A"
        android:textSize="17sp"
        android:fontFamily="@font/capriola_regular"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCurrent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Current Habits -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCurrentHabits"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="10dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tvCurrent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Completed Habits -->
    <TextView
        android:id="@+id/tvCompleted"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Completed Habits"
        android:textSize="36sp"
        android:textColor="#555555"
        android:fontFamily="@font/dongle_regular"
        android:visibility="gone"
        android:layout_marginStart="28dp"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/rvCurrentHabits"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Completed Recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCompletedHabits"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="90dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tvCompleted"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom Navigation -->
    <View
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="#A7C3A5"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Home -->
    <ImageView
        android:id="@+id/imgHome"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginStart="80dp"
        android:src="@drawable/ic_home"
        app:layout_constraintBottom_toBottomOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Statistics -->
    <ImageView
        android:id="@+id/imgStats"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="80dp"
        android:src="@drawable/ic_statistics"
        app:layout_constraintBottom_toBottomOf="@id/bottomNav"
        app:layout_constraintTop_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>