<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F4E7">

    <!-- Back -->
    <ImageView
        android:id="@+id/imgBack"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="67dp"
        android:src="@drawable/back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Leaf -->
    <ImageView
        android:id="@+id/imgLeaf"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="-47dp"
        android:layout_marginEnd="-80dp"
        android:rotation="-25"
        android:scaleType="fitCenter"
        android:src="@drawable/leaf"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="50dp"
        android:layout_marginTop="55dp"
        android:fontFamily="@font/capriola_regular"
        android:text="New Habit"
        android:textColor="#7FA48A"
        android:textSize="35sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- White Card -->

    <LinearLayout
        android:id="@+id/layoutHabitContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="60dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/add_habit_container"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Habit Name -->

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Habit Name"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHabitName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/capriola_regular"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Habit Color -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="@font/capriola_regular"
            android:text="Habit Color"
            android:textColor="#777777"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGreen"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="#B8E3C4"
                app:cardCornerRadius="15dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrange"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="#FFD3A8"
                app:cardCornerRadius="15dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBlue"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="#B7D7FF"
                app:cardCornerRadius="15dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPink"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="#FFD6E8"
                app:cardCornerRadius="15dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"/>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPurple"
                android:layout_width="30dp"
                android:layout_height="30dp"
                app:cardBackgroundColor="#DDB8F4"
                app:cardCornerRadius="15dp"
                app:strokeWidth="0dp"
                app:strokeColor="@android:color/transparent"/>

        </LinearLayout>

        <!-- Hours -->

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="Hours per Month"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTargetHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:fontFamily="@font/capriola_regular"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Times -->

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:hint="Times per Month"
            app:boxBackgroundMode="outline"
            app:boxCornerRadiusTopStart="12dp"
            app:boxCornerRadiusTopEnd="12dp"
            app:boxCornerRadiusBottomStart="12dp"
            app:boxCornerRadiusBottomEnd="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTargetTimes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:fontFamily="@font/capriola_regular"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Reminder -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/capriola_regular"
                android:text="Reminder"
                android:textColor="#555555"
                android:textSize="18sp"/>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/swReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="#FFFFFF"
                app:trackTint="#D8E7D7"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Create Button -->

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCreateHabit"
        android:layout_width="0dp"
        android:layout_height="58dp"
        android:layout_marginStart="55dp"
        android:layout_marginEnd="55dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="@font/capriola_regular"
        android:text="Create Habit"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        app:backgroundTint="#8DB493"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>